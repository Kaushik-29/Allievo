{
  "AUTO_APPROVE_NOTIFICATION": "\u0cb6\u0cc1\u0|cb8\u0cbe\u0cb0\u0ccd\u0ca4\u0cc6! \u20b9{amount} \u0ca8\u0cbf\u0cae\u0ccd\u0cae UPI\u0c97\u0cc6 \u0c95\u0cb³\u0cb3\u0cbe\u0caf\u0cbf\u0cb8\u0cb2\u0cbe\u0c97\u0cc1\u0ca4\u0cca\u0cc6.\n\u0c85\u0ca1\u0cbe\u0ca4\u0cb3: {disruption_event} | \u0cb5\u0cb²\u0caf: {zone_name} | \u0ca6\u0cbf\u0ca8\u0cbe\u0c82\u0c95: {date}\n\u0ca8\u0cbf\u0cb0\u0cc0\u0c95\u0ccd\u0cb6\u0cbf\u0ca4 \u0c86\u0c97\u0cae\u0ca8: 15 \u0ca8\u0cbf\u0cae\u0cbf\u0cb7\u0c97\u0cb3\u0cca\u0cb³\u0c97\u0cc6.",
  "SOFT_FLAG_NOTIFICATION": "{date} \u0cb0\u0c82\u0ca6\u0cc1 {disruption_event}\u0c97\u0cbe\u0c97\u0cbf \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0cd5\u0ca6\u0cyc\u0ca4\u0cc6 \u0caa\u0ccd\u0cb0\u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cbe\u0c97\u0cca\u0cb³\u0ccd\u0cb³\u0cc1\u0ca4\u0cca\u0cc6.\n\u20b9{first_amount} \u0c87\u0ca6\u0ccd\u0ca6\u0cc0\u0c97\u0cb3\u0cc7 \u0ca8\u0cbf\u0cae\u0ccd\u0cae UPI\u0c97\u0cc6 \u0c95\u0cb3\u0cc1\u0cb9\u0cbf\u0cb8\u0cb²\u0cbe\u0c97\u0cbf\u0ca6\u0cc6.\n\u0c89\u0cb³\u0cbf\u0ca6 \u20b9{held_amount} 24 \u0c97\u0c82\u0c9f\u0cc6\u0c97\u0cb3\u0cb3\u0ccd\u0cb3 \u0cac\u0cbf\u0ca1\u0cc1\u0c97\u0ca1\u0cc6\u0caf\u0cbe\u0c97\u0cc1\u0ca4\u0cca\u0cc6.\n\u0ca4\u0ca1\u0cb5\u0cbe\u0c97\u0cbf\u0ca6\u0ccd\u0ca6\u0c95\u0ccd\u0c95\u0cc6 \u0c95\u0cbe\u0cb0\u0ca3: {reason_text}\n\u0ca8\u0cc0\u0cb5\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc2 \u0cae\u0cbe\u0ca1\u0cb5\u0cc6 \u0cac\u0cc7\u0ca1 \u2014 \u0c87\u0ca6\u0cc1 \u0cb8\u0ccd\u0cb5\u0caf\u0c82\u0c9a\u0cbe\u0cb2\u0cbf\u0ca4\u0cb5\u0cbe\u0c97\u0cbf \u0caa\u0cb0\u0cbf\u0cb9\u0cbe\u0cb0\u0cb5\u0cbe\u0c97\u0cc1\u0ca4\u0cca\u0cc6.",
  "HARD_HOLD_NOTIFICATION": "{date} \u0cb0\u0c82\u0ca6\u0cc1 {disruption_event}\u0c97\u0cbe\u0c97\u0cbf \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0cd5\u0ca6\u0cyc\u0ca4\u0cc6 \u0caa\u0cb0\u0cbf\u0cb6\u0cc0\u0cb²\u0ca8\u0cc6\u0caf\u0cb²\u0ccd \u0c87\u0ca6\u0cc6.\n\u0c95\u0cbe\u0cb0\u0ca3: {reason_text}\n{date} \u0cb0\u0c82\u0ca6\u0cc1 {zone_name}\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0ca8\u0cc0\u0cb5\u0cc1 \u0c95\u0cc6\u0cb². \u0cae\u0cbe\u0ca1\u0cc1\u0ca4\u0cca\u0ccd\u0ca4\u0cbf\u0ca6\u0ccd\u0ca6\u0cbf\u0cb0\u0cbf \u0cc6\u0c82\u0ca6\u0cc1 \u0ca6\u0cc3\u0ca1\u0ccd\u0cda\u0caa\u0ca1\u0cbf\u0cb8\u0cae\u0cbf.\n[\u0cb9\u0cc8, \u0ca8\u0cbe\u0ca8\u0cc1 \u0c95\u0cc6\u0cb2\u0cb8 \u0cae\u0cbe\u0ca1\u0cc1\u0ca4\u0cca\u0ccd\u0ca4\u0cbf\u0ca6\u0ccd\u0ca6\u0cc6] [\u0c87\u0cb2\u0ccd\u0cb2, \u0ca8\u0cbe\u0ca8\u0cc1 \u0cae\u0cbe\u0ca1\u0cbf\u0cb2\u0ccd\u0cb2]\n\u0c90\u0c9a\u0ccd\u0c9b\u0cbf\u0c95 \u0c9f\u0cbf\u0caa\u0ccd\u0caa\u0ca3\u0cbf (100 \u0c85\u0c95\u0ccd\u0cb7\u0cb0): ___________\n48 \u0c97\u0c82\u0c9f\u0cc6\u0c97\u0cb3\u0cb3\u0ccd\u0cb3 \u0ca8\u0cbf\u0cae\u0ccd\u0cae\u0c97\u0cc6 \u0cac\u0ca6\u0cb² \u0cb8\u0cbf\u0c97\u0cc1\u0ca4\u0cca\u0cc6.",
  "PREMIUM_RENEWAL_NOTIFICATION": "\u0ca8\u0cbf\u0cae\u0ccd\u0cae Allievo \u0c95\u0cb5\u0cb0\u0cc7\u0c9c\u0cc1 \u0cb8\u0ccb\u0cae\u0cb5\u0cbe\u0cb0 \u0ca8\u0cb5\u0cc0\u0c95\u0cb0\u0cbc\u0cb5\u0cbe\u0c97\u0cc1\u0ca4\u0cca\u0cc6.\n\u0cae\u0cc1\u0c82\u0ca6\u0cbf\u0ca8 \u0cb5\u0cbe\u0cb0\u0ca6 \u0caa\u0ccd\u0cb0\u0cc0\u0cae\u0cbf\u0caf\u0c82: \u20b9{premium}\n\u0c95\u0cb5\u0cb0\u0cc7\u0c9c\u0cc1: {tier} \u2014 \u0cb5\u0cbe\u0cb0\u0c95\u0ccd\u0c95\u0cc6 \u20b9{max_payout} \u0cb5\u0cb0\u0cc6\n{premium_reason}\n[\u0ca8\u0ca8\u0ccd\u0ca8 \u0c95\u0cb5\u0cb0\u0cc7\u0c9c\u0cc1 \u0c87\u0ca1\u0cbf] [\u0c9f\u0cbf\u0caf\u0cb0\u0ccd \u0cac\u0ca6\u0cb2\u0cbf\u0cb8\u0cbf] [\u0c88 \u0cb5\u0cbe\u0cb0 \u0cac\u0cbf\u0ca1\u0cbf]\n\u0cb8\u0ccb\u0cae\u0cb5\u0cbe\u0cb0 11:59 PM\u0ca8\u0cca\u0cb3\u0c97\u0cc6 \u0ca8\u0cbf\u0cb0\u0ccd\u0ca7\u0cb0 \u0c89\u0cac\u0ccd\u0caa\u0cbf\u0cb0\u0cc1\u0cb5\u0cc1\u0ca6\u0cc1 \u0ca8\u0cbf\u0cae\u0ccd\u0cae\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0cb5\u0cb0\u0ccd \u0cae\u0cbe\u0ca1\u0cbf\u0ca6\u0cc6."
